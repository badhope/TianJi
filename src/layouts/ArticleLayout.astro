---
import BaseLayout from './BaseLayout.astro';
import { sectionColors, type SectionColor } from '@content/config';
import { SITE_CONFIG } from '@lib/constants';

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  section: string;
  sectionColor?: SectionColor;
  tags?: string[];
  era?: string;
  quote?: string;
  quoteSource?: string;
  updatedAt?: string;
  relatedArticles?: Array<{
    title: string;
    href: string;
    description: string;
  }>;
}

const {
  title,
  subtitle,
  description,
  section,
  sectionColor = 'gold',
  tags = [],
  era,
  quote,
  quoteSource,
  updatedAt,
  relatedArticles = [],
} = Astro.props;

const basePath = import.meta.env.BASE_URL || SITE_CONFIG.base;

const colorClasses: Record<SectionColor, { border: string; text: string; bg: string; badge: string }> = {
  gold: {
    border: 'border-[#c9a227]/30',
    text: 'text-[#d4af37]',
    bg: 'bg-[#c9a227]/[0.06]',
    badge: 'border-[#c9a227]/40 text-[#c9a227]',
  },
  jade: {
    border: 'border-[#2d8a8a]/30',
    text: 'text-[#5ababa]',
    bg: 'bg-[#2d8a8a]/[0.06]',
    badge: 'border-[#2d8a8a]/40 text-[#5ababa]',
  },
  ochre: {
    border: 'border-[#8a4a2d]/30',
    text: 'text-[#ba7a5a]',
    bg: 'bg-[#8a4a2d]/[0.06]',
    badge: 'border-[#8a4a2d]/40 text-[#ba7a5a]',
  },
  amethyst: {
    border: 'border-[#6b4a8a]/30',
    text: 'text-[#a878b8]',
    bg: 'bg-[#6b4a8a]/[0.06]',
    badge: 'border-[#6b4a8a]/40 text-[#a878b8]',
  },
  sapphire: {
    border: 'border-[#2d4a6b]/30',
    text: 'text-[#6b9ad4]',
    bg: 'bg-[#2d4a6b]/[0.06]',
    badge: 'border-[#2d4a6b]/40 text-[#6b9ad4]',
  },
};

const colors = colorClasses[sectionColor];
const sectionHref = `${basePath}/${section.toLowerCase()}`;
---

<BaseLayout title={title} description={description}>
  <article class="pt-20 pb-16">
    <header class="relative overflow-hidden">
      <div class={`absolute inset-0 ${colors.bg} opacity-50`}></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#080808]"></div>

      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
        <nav class="flex items-center gap-2 text-sm mb-8" aria-label="面包屑导航">
          <a href={basePath} class="text-[#666666] hover:text-[#c9a227] transition-colors">首页</a>
          <span class="text-[#444444]">/</span>
          <a href={sectionHref} class="text-[#666666] hover:text-[#c9a227] transition-colors">{section}</a>
          <span class="text-[#444444]">/</span>
          <span class="text-[#888888]">{title}</span>
        </nav>

        <div class="flex flex-wrap items-center gap-3 mb-6">
          <a
            href={sectionHref}
            class={`inline-block px-3 py-1 text-xs font-medium tracking-[0.15em] uppercase border rounded-full ${colors.badge} hover:opacity-80 transition-opacity`}
          >
            {section}
          </a>
          {era && (
            <span class="px-3 py-1 text-xs text-[#888888] border border-[#333333]/50 rounded-full">
              {era}
            </span>
          )}
        </div>

        <h1 class="text-3xl sm:text-4xl md:text-5xl font-display text-[#e8d48b] mb-4 tracking-wide leading-tight">
          {title}
        </h1>

        {subtitle && (
          <p class="text-xl sm:text-2xl text-[#c9a227]/80 font-light mb-6 leading-relaxed">
            {subtitle}
          </p>
        )}

        <p class="text-[#888888] text-lg leading-relaxed mb-8 max-w-3xl">
          {description}
        </p>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-6">
            {tags.map((tag) => (
              <span class="px-2.5 py-1 text-xs text-[#888888] bg-[#1a1a1a]/50 border border-[#2a2a2a] rounded">
                {tag}
              </span>
            ))}
          </div>
        )}

        <div class="gold-line max-w-[200px] opacity-40"></div>

        {updatedAt && (
          <p class="mt-4 text-xs text-[#555555]">
            最后更新：{updatedAt}
          </p>
        )}
      </div>
    </header>

    {quote && (
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-4 mb-8">
        <blockquote class="relative border-l-2 border-[#8b6914] pl-6 py-3 my-6">
          <div class={`absolute inset-0 ${colors.bg} rounded-r-lg`}></div>
          <p class="relative text-lg text-[#888888] italic leading-relaxed">
            {quote}
          </p>
          {quoteSource && (
            <footer class="relative mt-3 text-sm text-[#666666]">
              —— {quoteSource}
            </footer>
          )}
        </blockquote>
      </div>
    )}

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-12">
        <div class="prose-lingxu min-w-0">
          <slot />
        </div>

        <aside class="hidden lg:block">
          <div class="sticky top-24 space-y-6">
            <div class={`p-5 rounded-lg border ${colors.border} ${colors.bg}`}>
              <h3 class={`text-sm font-medium ${colors.text} mb-4 tracking-wide`}>目录</h3>
              <nav id="toc" class="space-y-2 text-sm">
              </nav>
            </div>

            {relatedArticles.length > 0 && (
              <div class={`p-5 rounded-lg border ${colors.border} bg-[#0a0a0a]/50`}>
                <h3 class={`text-sm font-medium ${colors.text} mb-4 tracking-wide`}>相关阅读</h3>
                <div class="space-y-4">
                  {relatedArticles.map((article) => (
                    <a href={article.href} class="block group">
                      <h4 class={`text-sm ${colors.text} group-hover:underline leading-snug`}>
                        {article.title}
                      </h4>
                      <p class="text-xs text-[#666666] mt-1 line-clamp-2">
                        {article.description}
                      </p>
                    </a>
                  ))}
                </div>
              </div>
            )}

            <a
              href={sectionHref}
              class="flex items-center gap-2 text-sm text-[#888888] hover:text-[#c9a227] transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17" />
              </svg>
              返回{section}
            </a>
          </div>
        </aside>
      </div>
    </div>

    <div class="lg:hidden max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mt-12">
      <div class={`p-4 rounded-lg border ${colors.border} ${colors.bg}`}>
        <button
          id="toc-toggle"
          class="flex items-center justify-between w-full text-left"
        >
          <span class={`text-sm font-medium ${colors.text}`}>目录</span>
          <svg id="toc-arrow" class={`w-4 h-4 ${colors.text} transition-transform`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <nav id="toc-mobile" class="hidden mt-4 space-y-2 text-sm text-[#888888]">
        </nav>
      </div>

      {relatedArticles.length > 0 && (
        <div class={`mt-6 p-4 rounded-lg border ${colors.border} bg-[#0a0a0a]/50`}>
          <h3 class={`text-sm font-medium ${colors.text} mb-4 tracking-wide`}>相关阅读</h3>
          <div class="space-y-4">
            {relatedArticles.map((article) => (
              <a href={article.href} class="block group">
                <h4 class={`text-sm ${colors.text} group-hover:underline leading-snug`}>
                  {article.title}
                </h4>
                <p class="text-xs text-[#666666] mt-1 line-clamp-2">
                  {article.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}

      <a
        href={sectionHref}
        class="flex items-center justify-center gap-2 mt-8 py-3 rounded-lg border border-[#333333] text-[#888888] hover:text-[#c9a227] hover:border-[#c9a227]/50 transition-all"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17" />
        </svg>
        返回{section}
      </a>
    </div>
  </article>
</BaseLayout>

<script>
  function initTOC() {
    const content = document.querySelector('.prose-lingxu');
    const toc = document.getElementById('toc');
    const tocMobile = document.getElementById('toc-mobile');
    const tocToggle = document.getElementById('toc-toggle');
    const tocArrow = document.getElementById('toc-arrow');

    if (!content || (!toc && !tocMobile)) return;

    const headings = content.querySelectorAll('h2, h3');

    if (headings.length === 0) {
      const container = toc || tocMobile;
      if (container) {
        container.innerHTML = '<p class="text-[#555555] text-xs">暂无目录</p>';
      }
      return;
    }

    const buildTOCItem = (level: number, text: string, href: string) => {
      const indent = level === 3 ? 'pl-3' : '';
      return `<a href="${href}" class="block text-[#888888] hover:text-[#c9a227] transition-colors py-1 ${indent}">${text}</a>`;
    };

    let tocHTML = '';
    headings.forEach((heading) => {
      const id = heading.id || heading.textContent?.trim().replace(/\s+/g, '-').toLowerCase() || '';
      if (!heading.id) heading.id = id;
      const level = parseInt(heading.tagName.charAt(1));
      tocHTML += buildTOCItem(level, heading.textContent || '', `#${id}`);
    });

    if (toc) toc.innerHTML = tocHTML;
    if (tocMobile) tocMobile.innerHTML = tocHTML;

    tocToggle?.addEventListener('click', () => {
      const isHidden = tocMobile?.classList.contains('hidden');
      tocMobile?.classList.toggle('hidden');
      tocArrow?.classList.toggle('rotate-180', isHidden);
    });
  }

  document.addEventListener('DOMContentLoaded', initTOC);
</script>
