---
import BaseLayout from './BaseLayout.astro';
import { type SectionColor } from '@content/config';
import { SITE_CONFIG } from '@lib/constants';

interface Props {
  title: string;
  description: string;
  section: string;
  sectionColor?: SectionColor;
  heroImage?: string;
}

const {
  title,
  description,
  section,
  sectionColor = 'gold',
  heroImage,
} = Astro.props;

const basePath = import.meta.env.BASE_URL || SITE_CONFIG.base;

const colorClasses: Record<SectionColor, { border: string; text: string; bg: string; badge: string; gradient: string }> = {
  gold: {
    border: 'border-[#c9a227]/30',
    text: 'text-[#d4af37]',
    bg: 'bg-[#c9a227]/[0.06]',
    badge: 'border-[#c9a227]/40 text-[#c9a227]',
    gradient: 'from-[#c9a227]/[0.03] via-transparent to-transparent',
  },
  jade: {
    border: 'border-[#2d8a8a]/30',
    text: 'text-[#5ababa]',
    bg: 'bg-[#2d8a8a]/[0.06]',
    badge: 'border-[#2d8a8a]/40 text-[#5ababa]',
    gradient: 'from-[#2d8a8a]/[0.03] via-transparent to-transparent',
  },
  ochre: {
    border: 'border-[#8a4a2d]/30',
    text: 'text-[#ba7a5a]',
    bg: 'bg-[#8a4a2d]/[0.06]',
    badge: 'border-[#8a4a2d]/40 text-[#ba7a5a]',
    gradient: 'from-[#8a4a2d]/[0.03] via-transparent to-transparent',
  },
  amethyst: {
    border: 'border-[#6b4a8a]/30',
    text: 'text-[#a878b8]',
    bg: 'bg-[#6b4a8a]/[0.06]',
    badge: 'border-[#6b4a8a]/40 text-[#a878b8]',
    gradient: 'from-[#6b4a8a]/[0.03] via-transparent to-transparent',
  },
  sapphire: {
    border: 'border-[#2d4a6b]/30',
    text: 'text-[#6b9ad4]',
    bg: 'bg-[#2d4a6b]/[0.06]',
    badge: 'border-[#2d4a6b]/40 text-[#6b9ad4]',
    gradient: 'from-[#2d4a6b]/[0.03] via-transparent to-transparent',
  },
};

const colors = colorClasses[sectionColor];
const sectionHref = `/${section.toLowerCase()}`;
---

<BaseLayout title={`${title} - ${section}`} description={description}>
  <article class="pt-20 pb-16">
    <header class={`relative overflow-hidden bg-gradient-to-b ${colors.gradient}`}>
      <div class="absolute inset-0">
        <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full bg-gradient-to-br from-[#c9a227]/[0.05] to-transparent blur-3xl"></div>
        <div class="absolute bottom-0 right-1/4 w-64 h-64 rounded-full bg-gradient-to-tr from-[#6b4a8a]/[0.03] to-transparent blur-2xl"></div>
      </div>

      <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
        <nav class="flex items-center gap-2 text-sm mb-8" aria-label="面包屑导航">
          <a href={basePath} class="text-[#666666] hover:text-[#c9a227] transition-colors">首页</a>
          <span class="text-[#444444]">/</span>
          <span class="text-[#888888]">{section}</span>
        </nav>

        <div class="flex items-center gap-3 mb-6">
          <span class={`px-3 py-1 text-xs font-medium tracking-[0.15em] uppercase border rounded-full ${colors.badge}`}>
            {section}
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-display text-[#e8d48b] mb-6 tracking-wide leading-tight">
          {title}
        </h1>

        <p class="text-lg sm:text-xl text-[#888888] leading-relaxed mb-10 max-w-3xl">
          {description}
        </p>

        <div class="gold-line max-w-[240px] opacity-50"></div>
      </div>
    </header>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mt-12">
      <slot />
    </div>
  </article>
</BaseLayout>
