---
import BaseLayout from './BaseLayout.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';

interface Props {
  title: string;
  description: string;
  section: string;
  sectionColor: string;
  entries?: Array<{title: string; href: string; description: string}>;
}

const { title, description, section, sectionColor, entries = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="pt-24 pb-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <SectionHeader
        title={title}
        description={description}
        section={section}
        color={sectionColor}
      />
      <slot />
      {entries.length > 0 && (
        <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {entries.map((entry) => (
            <a
              href={entry.href}
              class="section-card group block"
            >
              <h3 class="text-xl font-display text-gold-300 group-hover:text-gold-200 transition-colors">
                {entry.title}
              </h3>
              <p class="mt-3 text-ink-400 group-hover:text-ink-300 transition-colors">
                {entry.description}
              </p>
              <div class="mt-4 flex items-center text-gold-500 text-sm opacity-0 group-hover:opacity-100 transition-opacity">
                <span>阅读全文</span>
                <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </article>
</BaseLayout>
