---
import { SITE_CONFIG } from '@lib/constants';
---

<footer class="relative z-20 border-t border-[#1a1a1a] bg-[#050505]/90 backdrop-blur-sm">
  <div class="absolute inset-0 bg-gradient-to-t from-[#080808] to-transparent pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 sm:px-8 py-16">
    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full border border-[#c9a227]/30 flex items-center justify-center">
            <svg class="w-5 h-5 text-[#c9a227]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
          </div>
          <span class="font-display text-xl text-[#d4af37] tracking-[0.2em]">{SITE_CONFIG.name}</span>
        </div>
        <p class="text-[#666666] text-sm leading-loose">
          {SITE_CONFIG.description}
        </p>
      </div>

      <div>
        <h4 class="text-[#c9a227]/80 text-sm font-medium tracking-wider mb-6">探索</h4>
        <ul class="space-y-3">
          <li><a href="/archive" class="text-[#555555] hover:text-[#d4af37] transition-colors text-sm">档案馆</a></li>
          <li><a href="/medicine" class="text-[#555555] hover:text-[#d4af37] transition-colors text-sm">医药</a></li>
          <li><a href="/myth" class="text-[#555555] hover:text-[#d4af37] transition-colors text-sm">神话</a></li>
          <li><a href="/dharma" class="text-[#555555] hover:text-[#d4af37] transition-colors text-sm">法脉</a></li>
          <li><a href="/realms" class="text-[#555555] hover:text-[#d4af37] transition-colors text-sm">境界</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[#c9a227]/80 text-sm font-medium tracking-wider mb-6">关于</h4>
        <ul class="space-y-3">
          <li><a href="/about" class="text-[#555555] hover:text-[#d4af37] transition-colors text-sm">项目缘起</a></li>
        </ul>
        <div class="mt-8 pt-6 border-t border-[#1a1a1a]">
          <div class="flex items-center gap-2 text-xs text-[#444444]">
            <span class="text-[#d4af37]">中</span>
            <span class="text-[#333333]">/</span>
            <span class="text-[#444444]">EN 暂未开放</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8">
      <div class="gold-line mb-8 opacity-50"></div>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-[#444444] text-xs tracking-wider">
          © 二〇二四 {SITE_CONFIG.name} · {SITE_CONFIG.subtitle}
        </p>
        <p class="text-[#333333] text-xs tracking-wider">
          愿见者得度，闻者觉悟
        </p>
      </div>
    </div>
  </div>
</footer>
