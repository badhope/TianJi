---
import { SITE_CONFIG } from '@lib/constants';
---

<footer class="relative z-20 border-t border-ink-800/50 bg-ink-950/90 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <div class="flex items-center space-x-3 mb-4">
          <span class="font-display text-xl text-gold-400 tracking-wider">{SITE_CONFIG.name}</span>
        </div>
        <p class="text-ink-500 text-sm leading-relaxed">
          {SITE_CONFIG.description}
        </p>
      </div>

      <div>
        <h4 class="text-ink-300 font-medium mb-4">探索</h4>
        <ul class="space-y-2 text-sm text-ink-500">
          <li><a href="/archive" class="hover:text-gold-400 transition-colors">档案馆</a></li>
          <li><a href="/medicine" class="hover:text-gold-400 transition-colors">医药</a></li>
          <li><a href="/myth" class="hover:text-gold-400 transition-colors">神话</a></li>
          <li><a href="/dharma" class="hover:text-gold-400 transition-colors">法脉</a></li>
          <li><a href="/realms" class="hover:text-gold-400 transition-colors">境界</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-ink-300 font-medium mb-4">关于</h4>
        <ul class="space-y-2 text-sm text-ink-500">
          <li><a href="/about" class="hover:text-gold-400 transition-colors">项目缘起</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-ink-800/50">
      <div class="gold-line mb-6"></div>
      <p class="text-center text-ink-600 text-sm">
        © 2024 {SITE_CONFIG.name} · {SITE_CONFIG.subtitle}
      </p>
    </div>
  </div>
</footer>
