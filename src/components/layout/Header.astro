---
import { NAV_ITEMS } from '@data/navigation';

const pathname = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-[#080808]/85 border-b border-[#1f1f1f]/60">
  <div class="absolute inset-0 bg-gradient-to-b from-[#c9a227]/[0.02] to-transparent pointer-events-none"></div>

  <nav class="relative max-w-7xl mx-auto px-6 sm:px-8">
    <div class="flex items-center justify-between h-[4.5rem]">
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative">
          <div class="w-10 h-10 rounded-full border border-[#c9a227]/40 flex items-center justify-center group-hover:border-[#d4af37]/70 transition-all duration-500 group-hover:shadow-[0_0_20px_rgba(201,162,39,0.2)]">
            <svg class="w-5 h-5 text-[#c9a227]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
          </div>
          <div class="absolute inset-0 rounded-full border border-[#c9a227]/20 scale-110 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        </div>
        <div class="flex flex-col">
          <span class="font-display text-xl text-[#d4af37] tracking-[0.2em]">灵墟</span>
          <span class="text-[10px] text-[#666666] tracking-widest hidden sm:block">失落修行文明档案</span>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-10">
        {NAV_ITEMS.map((item) => {
          const isActive = pathname.startsWith(item.href);
          return (
            <a
              href={item.href}
              class={`relative py-2 text-sm font-medium tracking-wide transition-all duration-300 ${
                isActive
                  ? 'text-[#d4af37]'
                  : 'text-[#888888] hover:text-[#c9a227]'
              }`}
            >
              {item.label}
              <span class={`absolute bottom-0 left-0 right-0 h-px bg-[#c9a227] transition-all duration-300 ${
                isActive ? 'opacity-100' : 'opacity-0 group-hover:opacity-50'
              }`}></span>
              {isActive && (
                <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-[#c9a227]"></span>
              )}
            </a>
          );
        })}
      </div>

      <div class="flex items-center gap-4">
        <button
          class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-[#333333] text-xs text-[#666666] hover:border-[#c9a227]/50 hover:text-[#c9a227] transition-all duration-300"
          title="语言切换（暂未开放）"
        >
          <span class="text-[#d4af37]">中</span>
          <span class="text-[#444444]">/</span>
          <span class="text-[#555555]">EN</span>
          <svg class="w-3 h-3 ml-1 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </button>

        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-[#888888] hover:text-[#d4af37] transition-colors"
          aria-label="菜单"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden lg:hidden pb-6">
      <div class="flex flex-col gap-1">
        {NAV_ITEMS.map((item) => {
          const isActive = pathname.startsWith(item.href);
          return (
            <a
              href={item.href}
              class={`px-4 py-3 rounded-lg text-sm font-medium transition-all ${
                isActive
                  ? 'text-[#d4af37] bg-[#c9a227]/[0.08] border-l-2 border-[#c9a227]'
                  : 'text-[#888888] hover:text-[#c9a227] hover:bg-[#1a1a1a]/50'
              }`}
            >
              {item.label}
            </a>
          );
        })}
        <div class="flex items-center gap-2 px-4 py-3 mt-2 text-xs text-[#555555] border-t border-[#2a2a2a] pt-4">
          <span class="text-[#d4af37]">中</span>
          <span class="text-[#444444]">/</span>
          <span class="text-[#555555]">EN 暂未开放</span>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('#mobile-menu-btn') && !target.closest('#mobile-menu')) {
      mobileMenu?.classList.add('hidden');
    }
  });
</script>
