---
import { NAV_ITEMS } from '@data/navigation';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const parentPath = '/' + currentPath.split('/').filter(Boolean)[0];
---

<nav class="sticky top-20 py-4">
  <div class="text-sm text-[#666666] mb-4">章节导航</div>
  <ul class="space-y-2">
    {NAV_ITEMS.map((item) => {
      const isActive = parentPath === item.href;
      return (
        <li>
          <a
            href={item.href}
            class={`block py-1.5 px-3 rounded transition-all ${
              isActive
                ? 'text-[#d4af37] bg-[#c9a227]/[0.08] border-l-2 border-[#d4af37]'
                : 'text-[#888888] hover:text-[#c9a227] hover:bg-[#1a1a1a]/50'
            }`}
          >
            {item.label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
