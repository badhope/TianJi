---
import { NAV_ITEMS } from '@data/navigation';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const parentPath = '/' + currentPath.split('/').filter(Boolean)[0];
---

<nav class="sticky top-20 py-4">
  <div class="text-sm text-ink-500 mb-4">章节导航</div>
  <ul class="space-y-2">
    {NAV_ITEMS.map((item) => {
      const isActive = parentPath === item.href;
      return (
        <li>
          <a
            href={item.href}
            class={`block py-1.5 px-3 rounded transition-all ${
              isActive
                ? 'text-gold-400 bg-gold-900/20 border-l-2 border-gold-500'
                : 'text-ink-400 hover:text-gold-300 hover:bg-ink-800/30'
            }`}
          >
            {item.label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
