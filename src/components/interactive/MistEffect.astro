<div class="mist-overlay fixed inset-0 pointer-events-none z-10 overflow-hidden">
  <div class="mist mist-1"></div>
  <div class="mist mist-2"></div>
  <div class="mist mist-3"></div>
</div>

<style>
  .mist-overlay {
    opacity: 0.4;
  }

  .mist {
    position: absolute;
    width: 200%;
    height: 200%;
    background: radial-gradient(ellipse at center, rgba(201, 162, 39, 0.03) 0%, transparent 70%);
    animation: drift 30s ease-in-out infinite;
  }

  .mist-1 {
    top: -50%;
    left: -50%;
    animation-delay: 0s;
  }

  .mist-2 {
    top: 0%;
    left: 0%;
    animation-delay: -10s;
    animation-duration: 25s;
  }

  .mist-3 {
    top: -25%;
    left: -25%;
    animation-delay: -20s;
    animation-duration: 35s;
  }

  @keyframes drift {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg);
    }
    25% {
      transform: translate(5%, 3%) rotate(2deg);
    }
    50% {
      transform: translate(-3%, 5%) rotate(-1deg);
    }
    75% {
      transform: translate(-5%, -3%) rotate(1deg);
    }
  }
</style>
