---
export interface Props {
  mode?: 'gradient' | 'particles' | 'parallax' | 'all';
  particleDensity?: number;
  enableParallax?: boolean;
}

const {
  mode = 'all',
  particleDensity = 80,
  enableParallax = true
} = Astro.props;
---

<div id="dynamic-bg" class="fixed inset-0 -z-10 overflow-hidden">
  <div id="gradient-layer" class="absolute inset-0"></div>
  <canvas id="bg-particle-canvas" class="absolute inset-0"></canvas>
  <div id="parallax-container" class="absolute inset-0">
    <div class="parallax-layer" data-depth="0.1" data-speed="0.5">
      <div class="absolute -top-20 -left-20 w-96 h-96 rounded-full bg-[radial-gradient(circle,rgba(201,162,39,0.03)_0%,transparent_70%)]"></div>
    </div>
    <div class="parallax-layer" data-depth="0.2" data-speed="1">
      <div class="absolute top-1/4 -right-20 w-80 h-80 rounded-full bg-[radial-gradient(circle,rgba(90,186,186,0.02)_0%,transparent_70%)]"></div>
    </div>
    <div class="parallax-layer" data-depth="0.15" data-speed="0.75">
      <div class="absolute bottom-20 left-1/4 w-64 h-64 rounded-full bg-[radial-gradient(circle,rgba(168,120,184,0.02)_0%,transparent_70%)]"></div>
    </div>
    <div class="parallax-layer" data-depth="0.25" data-speed="1.5">
      <div class="absolute top-1/2 right-1/3 w-72 h-72 rounded-full bg-[radial-gradient(circle,rgba(201,162,39,0.025)_0%,transparent_70%)]"></div>
    </div>
    <div class="parallax-layer" data-depth="0.05" data-speed="0.25">
      <div class="absolute -bottom-10 right-1/4 w-56 h-56 rounded-full bg-[radial-gradient(circle,rgba(107,74,138,0.03)_0%,transparent_70%)]"></div>
    </div>
  </div>
</div>

<script define:vars={{ mode, particleDensity, enableParallax }}>
  class GradientFlow {
    private el: HTMLElement;
    private hue: number = 38;
    private animationId: number = 0;

    constructor(el: HTMLElement) {
      this.el = el;
      this.init();
    }

    private init() {
      if (mode !== 'gradient' && mode !== 'all') return;

      this.el.style.cssText = `
        background: radial-gradient(ellipse at 20% 0%, rgba(201, 162, 39, 0.04) 0%, transparent 50%),
                    radial-gradient(ellipse at 80% 100%, rgba(107, 74, 138, 0.04) 0%, transparent 50%);
        animation: gradientShift 90s ease-in-out infinite;
      `;

      const style = document.createElement('style');
      style.textContent = `
        @keyframes gradientShift {
          0%, 100% {
            background-position: 0% 50%;
            filter: hue-rotate(0deg);
          }
          25% {
            background-position: 50% 100%;
            filter: hue-rotate(5deg);
          }
          50% {
            background-position: 100% 50%;
            filter: hue-rotate(0deg);
          }
          75% {
            background-position: 50% 0%;
            filter: hue-rotate(-5deg);
          }
        }
      `;
      document.head.appendChild(style);
    }
  }

  class CanvasBackground {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private particles: Particle[] = [];
    private maxParticles: number;
    private animationId: number = 0;
    private isMobile: boolean;
    private mouseX: number = 0;
    private mouseY: number = 0;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d');
      this.isMobile = window.innerWidth < 768;
      this.maxParticles = this.isMobile ? Math.floor(particleDensity * 0.5) : particleDensity;
      this.init();
    }

    private init() {
      if (mode !== 'particles' && mode !== 'all') return;

      this.resize();
      this.createParticles();
      this.bindEvents();
      this.animate();
    }

    private resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
    }

    private createParticles() {
      this.particles = [];
      for (let i = 0; i < this.maxParticles; i++) {
        this.particles.push(this.createParticle());
      }
    }

    private createParticle(): Particle {
      return {
        x: Math.random() * this.canvas.width,
        y: Math.random() * this.canvas.height,
        size: Math.random() * 2 + 0.5,
        speedX: (Math.random() - 0.5) * 0.3,
        speedY: (Math.random() - 0.5) * 0.3,
        opacity: Math.random() * 0.4 + 0.1,
        hue: 38 + Math.random() * 10 - 5
      };
    }

    private bindEvents() {
      let resizeTimeout;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
          this.resize();
          this.createParticles();
        }, 250);
      }, { passive: true });

      document.addEventListener('mousemove', (e) => {
        this.mouseX = e.clientX;
        this.mouseY = e.clientY;
      }, { passive: true });
    }

    private animate = () => {
      if (mode !== 'particles' && mode !== 'all') return;

      this.animationId = requestAnimationFrame(this.animate);

      this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

      this.particles.forEach((p, i) => {
        p.x += p.speedX;
        p.y += p.speedY;

        const dx = this.mouseX - p.x;
        const dy = this.mouseY - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 150) {
          const force = (150 - dist) / 150 * 0.02;
          p.x -= dx * force;
          p.y -= dy * force;
        }

        if (p.x < 0) p.x = this.canvas.width;
        if (p.x > this.canvas.width) p.x = 0;
        if (p.y < 0) p.y = this.canvas.height;
        if (p.y > this.canvas.height) p.y = 0;

        this.ctx.beginPath();
        this.ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        this.ctx.fillStyle = `hsla(${p.hue}, 60%, 65%, ${p.opacity})`;
        this.ctx.fill();
      });

      for (let i = 0; i < this.particles.length; i++) {
        for (let j = i + 1; j < this.particles.length; j++) {
          const dx = this.particles[i].x - this.particles[j].x;
          const dy = this.particles[i].y - this.particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < 100) {
            this.ctx.beginPath();
            this.ctx.moveTo(this.particles[i].x, this.particles[i].y);
            this.ctx.lineTo(this.particles[j].x, this.particles[j].y);
            this.ctx.strokeStyle = `rgba(201, 162, 39, ${0.1 * (1 - dist / 100)})`;
            this.ctx.lineWidth = 0.5;
            this.ctx.stroke();
          }
        }
      }
    };

    public destroy() {
      cancelAnimationFrame(this.animationId);
    }
  }

  interface Particle {
    x: number;
    y: number;
    size: number;
    speedX: number;
    speedY: number;
    opacity: number;
    hue: number;
  }

  class ParallaxBackground {
    private layers: NodeListOf<Element>;
    private animationId: number = 0;

    constructor() {
      if (!enableParallax || (mode !== 'parallax' && mode !== 'all')) return;

      this.layers = document.querySelectorAll('.parallax-layer');
      if (this.layers.length === 0) return;

      this.bindEvents();
      this.animate();
    }

    private bindEvents() {
      let lastY = 0;
      window.addEventListener('scroll', () => {
        lastY = window.scrollY;
        this.update(lastY);
      }, { passive: true });
    }

    private update(scrollY: number) {
      this.layers.forEach((layer) => {
        const el = layer as HTMLElement;
        const depth = parseFloat(el.dataset.depth || '0.1');
        const speed = parseFloat(el.dataset.speed || '1');
        const movement = scrollY * depth * speed * 0.1;
        el.style.transform = `translateY(${movement}px)`;
      });
    }

    private animate = () => {
      if (!enableParallax || (mode !== 'parallax' && mode !== 'all')) return;
      this.animationId = requestAnimationFrame(this.animate);
    };

    public destroy() {
      cancelAnimationFrame(this.animationId);
    }
  }

  document.addEventListener('astro:page-load', () => {
    const gradientLayer = document.getElementById('gradient-layer');
    const canvas = document.getElementById('bg-particle-canvas') as HTMLCanvasElement;
    const container = document.getElementById('parallax-container');

    if (gradientLayer) new GradientFlow(gradientLayer);
    if (canvas && mode !== 'parallax') new CanvasBackground(canvas);
    if (container) new ParallaxBackground();
  });
</script>