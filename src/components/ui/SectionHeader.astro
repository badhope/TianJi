---
interface Props {
  title: string;
  description?: string;
  section?: string;
  color?: string;
}

const { title, description, section, color = 'gold' } = Astro.props;

const colorMap: Record<string, { border: string; text: string }> = {
  gold: { border: 'border-[#c9a227]/30', text: 'text-[#d4af37]' },
  jade: { border: 'border-[#2d8a8a]/30', text: 'text-[#5ababa]' },
  ochre: { border: 'border-[#8a4a2d]/30', text: 'text-[#ba7a5a]' },
  amethyst: { border: 'border-[#6b4a8a]/30', text: 'text-[#a878b8]' },
  sapphire: { border: 'border-[#2d4a6b]/30', text: 'text-[#6b9ad4]' },
};

const colors = colorMap[color] || colorMap.gold;
---

<header class="text-center mb-20">
  {section && (
    <div class="inline-flex items-center gap-3 mb-6">
      <div class={`h-px w-12 ${colors.text}/30`}></div>
      <span class={`px-4 py-1.5 text-xs font-medium tracking-[0.2em] uppercase border rounded-full ${colors.border} ${colors.text}`}>
        {section}
      </span>
      <div class={`h-px w-12 ${colors.text}/30`}></div>
    </div>
  )}
  <h2 class="text-3xl sm:text-4xl md:text-5xl font-display text-[#e8d48b] mb-6 tracking-wide">
    {title}
  </h2>
  {description && (
    <p class="text-[#888888] text-lg max-w-2xl mx-auto leading-relaxed">
      {description}
    </p>
  )}
  <div class="gold-line mt-10 max-w-[200px] mx-auto opacity-40"></div>
</header>
