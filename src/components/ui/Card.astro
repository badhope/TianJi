---
interface Props {
  title: string;
  description?: string;
  href?: string;
  variant?: 'default' | 'featured';
  color?: 'gold' | 'jade' | 'ochre' | 'amethyst' | 'sapphire';
}

const { title, description, href, variant = 'default', color = 'gold' } = Astro.props;

const colorMap = {
  gold: {
    border: 'border-[#c9a227]/30 hover:border-[#d4af37]/60',
    text: 'text-[#d4af37]',
    bg: 'hover:bg-[#c9a227]/[0.05]',
  },
  jade: {
    border: 'border-[#2d8a8a]/30 hover:border-[#5ababa]/60',
    text: 'text-[#5ababa]',
    bg: 'hover:bg-[#2d8a8a]/[0.05]',
  },
  ochre: {
    border: 'border-[#8a4a2d]/30 hover:border-[#ba7a5a]/60',
    text: 'text-[#ba7a5a]',
    bg: 'hover:bg-[#8a4a2d]/[0.05]',
  },
  amethyst: {
    border: 'border-[#6b4a8a]/30 hover:border-[#a878b8]/60',
    text: 'text-[#a878b8]',
    bg: 'hover:bg-[#6b4a8a]/[0.05]',
  },
  sapphire: {
    border: 'border-[#2d4a6b]/30 hover:border-[#6b9ad4]/60',
    text: 'text-[#6b9ad4]',
    bg: 'hover:bg-[#2d4a6b]/[0.05]',
  },
};

const colors = colorMap[color] || colorMap.gold;

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class={`section-card group ${href ? 'block' : ''} ${colors.border} ${colors.bg}`}
>
  <h3 class={`text-xl font-display ${colors.text} group-hover:translate-x-1 transition-transform`}>
    {title}
  </h3>
  {description && (
    <p class="mt-3 text-[#888888] group-hover:text-[#a0a0a0] transition-colors">
      {description}
    </p>
  )}
  <slot />
</Tag>
