---
import { TIMELINE } from '@data/timeline';
---

<div class="relative">
  <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-gold-700/50 via-gold-500/30 to-gold-700/50"></div>

  <div class="space-y-12">
    {TIMELINE.map((item, index) => (
      <div class="relative pl-12 md:pl-0">
        <div class={`absolute left-0 md:left-1/2 w-8 h-8 rounded-full border-2 flex items-center justify-center transform md:-translate-x-1/2 ${
          index === TIMELINE.length - 1
            ? 'border-gold-400 bg-ink-900 text-gold-400'
            : 'border-gold-700/50 bg-ink-950 text-ink-500'
        }`}>
          <span class="text-sm">{index + 1}</span>
        </div>

        <div class={`md:w-[calc(50%-2rem)] ${index % 2 === 0 ? 'md:ml-auto md:pr-8' : 'md:mr-auto md:pl-8'}`}>
          <div class="p-4 rounded-lg bg-ink-900/50 border border-ink-800/30 hover:border-gold-700/30 transition-colors">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl">{item.icon}</span>
              <h3 class="text-lg font-display text-gold-300">{item.era}</h3>
            </div>
            <p class="text-sm text-jade-400/80 mb-2">{item.period}</p>
            <p class="text-ink-400 text-sm leading-relaxed">{item.description}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
