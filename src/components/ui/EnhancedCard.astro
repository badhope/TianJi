---
export interface Props {
  href?: string;
  title: string;
  description?: string;
  icon?: string;
  sectionColor?: 'gold' | 'jade' | 'ochre' | 'amethyst' | 'sapphire';
  variant?: 'default' | 'elevated' | 'glow';
  delay?: number;
}

const {
  href,
  title,
  description,
  icon,
  sectionColor = 'gold',
  variant = 'default',
  delay = 0
} = Astro.props;

const colorMap = {
  gold: {
    border: 'hover:border-[#c9a227]/60',
    text: 'text-[#e8c76b]',
    glow: 'hover:shadow-[0_0_25px_rgba(201,162,39,0.25)]',
    gradient: 'from-[#c9a227]/10'
  },
  jade: {
    border: 'hover:border-[#5ababa]/60',
    text: 'text-[#7dc4c4]',
    glow: 'hover:shadow-[0_0_25px_rgba(90,186,186,0.25)]',
    gradient: 'from-[#5ababa]/10'
  },
  ochre: {
    border: 'hover:border-[#ba7a5a]/60',
    text: 'text-[#c99a7a]',
    glow: 'hover:shadow-[0_0_25px_rgba(186,122,90,0.25)]',
    gradient: 'from-[#ba7a5a]/10'
  },
  amethyst: {
    border: 'hover:border-[#a878b8]/60',
    text: 'text-[#b890c4]',
    glow: 'hover:shadow-[0_0_25px_rgba(168,120,184,0.25)]',
    gradient: 'from-[#a878b8]/10'
  },
  sapphire: {
    border: 'hover:border-[#6b9ad4]/60',
    text: 'text-[#8ab0e0]',
    glow: 'hover:shadow-[0_0_25px_rgba(107,154,212,0.25)]',
    gradient: 'from-[#6b9ad4]/10'
  }
};

const colors = colorMap[sectionColor];
const isLink = !!href;
const Tag = isLink ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'card-enhanced group relative block p-6 rounded-xl bg-[#0a0a0a]/80 border border-[#2a2a2a]/60',
    'transition-all duration-500 ease-out',
    'hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(0,0,0,0.4)]',
    colors.border,
    colors.glow,
    variant === 'glow' && 'card-glow-effect',
    variant === 'elevated' && 'hover:shadow-[0_12px_40px_rgba(0,0,0,0.5)]'
  ]}
  style={`transition-delay: ${delay}ms`}
>
  <div class:list={[
    'absolute inset-0 rounded-xl opacity-0 transition-opacity duration-500',
    'bg-gradient-to-br bg-[length:200%_200%]',
    colors.gradient,
    'group-hover:opacity-100'
  ]}></div>

  {variant === 'glow' && (
    <div class="card-glow-line absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-current to-transparent opacity-0 group-hover:opacity-50 transition-opacity duration-500"></div>
  )}

  <div class="relative z-10">
    {icon && (
      <div class="mb-4 text-2xl">{icon}</div>
    )}

    <h3 class:list={[
      'text-lg font-display mb-2 tracking-wide transition-colors duration-300',
      colors.text
    ]}>
      <span class="card-title-inner">{title}</span>
    </h3>

    {description && (
      <p class="text-sm text-[#888888] leading-relaxed opacity-80 group-hover:opacity-100 transition-opacity duration-500">
        {description}
      </p>
    )}

    <div class="mt-4 pt-4 border-t border-[#2a2a2a]/50 opacity-50 group-hover:opacity-100 transition-opacity duration-500">
      <span class="text-xs text-[#c9a227]/50 group-hover:text-[#c9a227]/80 transition-colors tracking-wider">
        {isLink ? '探索更多 →' : '查看详情 →'}
      </span>
    </div>
  </div>

  <div class="card-highlight-line absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
</Tag>

<style>
  .card-enhanced {
    will-change: transform, box-shadow;
  }

  .card-enhanced:active {
    transform: scale(0.99);
  }

  .card-glow-effect {
    position: relative;
  }

  .card-glow-effect::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(201, 162, 39, 0.3), transparent 50%, rgba(201, 162, 39, 0.1));
    opacity: 0;
    transition: opacity 0.5s ease-out;
    z-index: -1;
  }

  .card-glow-effect:hover::before {
    opacity: 1;
  }

  .card-title-inner {
    display: inline-block;
    transition: transform 0.3s ease-out;
  }

  .card-enhanced:hover .card-title-inner {
    transform: translateX(2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .card-enhanced,
    .card-enhanced *,
    .card-glow-effect::before {
      transition: none !important;
      animation: none !important;
    }
  }
</style>