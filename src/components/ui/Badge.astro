---
interface Props {
  variant?: 'solid' | 'outline';
  color?: string;
}

const { variant = 'outline', color = 'gold' } = Astro.props;

const colorMap: Record<string, Record<string, string>> = {
  gold: {
    solid: 'bg-[#c9a227]/20 text-[#e8c76b] border-[#c9a227]/40',
    outline: 'bg-transparent text-[#c9a227] border-[#c9a227]/40 hover:bg-[#c9a227]/10',
  },
  jade: {
    solid: 'bg-[#2d8a8a]/20 text-[#5ababa] border-[#2d8a8a]/40',
    outline: 'bg-transparent text-[#5ababa] border-[#2d8a8a]/40 hover:bg-[#2d8a8a]/10',
  },
  ochre: {
    solid: 'bg-[#8a4a2d]/20 text-[#ba7a5a] border-[#8a4a2d]/40',
    outline: 'bg-transparent text-[#ba7a5a] border-[#8a4a2d]/40 hover:bg-[#8a4a2d]/10',
  },
  amethyst: {
    solid: 'bg-[#6b4a8a]/20 text-[#a878b8] border-[#6b4a8a]/40',
    outline: 'bg-transparent text-[#a878b8] border-[#6b4a8a]/40 hover:bg-[#6b4a8a]/10',
  },
  sapphire: {
    solid: 'bg-[#2d4a6b]/20 text-[#6b9ad4] border-[#2d4a6b]/40',
    outline: 'bg-transparent text-[#6b9ad4] border-[#2d4a6b]/40 hover:bg-[#2d4a6b]/10',
  },
};

const styles = colorMap[color]?.[variant] || colorMap.gold.outline;
---

<span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-medium tracking-wide border ${styles}`}>
  <slot />
</span>
