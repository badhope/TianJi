---

---

<div id="portal-overlay" class="fixed inset-0 z-[9999] bg-[#050508] overflow-hidden">
  <div id="portal-bg" class="absolute inset-0">
    <div class="portal-mist portal-mist-1"></div>
    <div class="portal-mist portal-mist-2"></div>
    <div class="portal-mist portal-mist-3"></div>
    <canvas id="portal-particle-canvas" class="absolute inset-0 pointer-events-none z-[1]"></canvas>
  </div>

  <div id="portal-depth" class="absolute inset-0 pointer-events-none">
    <div class="absolute bottom-0 left-0 right-0 h-[40%] bg-gradient-to-t from-[#050508] via-transparent to-transparent"></div>
    <div class="absolute top-[10%] left-1/2 -translate-x-1/2 w-[120%] h-[60%] bg-gradient-to-b from-[#c9a227]/[0.02] via-transparent to-transparent blur-3xl"></div>
  </div>

  <div id="portal-gate" class="absolute inset-0 flex items-center justify-center">
    <div class="relative w-full h-full flex items-center justify-center">
      <svg id="gate-svg" class="w-[260px] h-[260px] sm:w-[300px] sm:h-[300px] md:w-[380px] md:h-[380px] lg:w-[420px] lg:h-[420px]" viewBox="0 0 400 400" fill="none">
        <defs>
          <radialGradient id="gateGlow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#d4af37" stop-opacity="0.12"/>
            <stop offset="60%" stop-color="#c9a227" stop-opacity="0.04"/>
            <stop offset="100%" stop-color="#c9a227" stop-opacity="0"/>
          </radialGradient>
          <radialGradient id="coreGlow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#d4af37" stop-opacity="0.4"/>
            <stop offset="100%" stop-color="#d4af37" stop-opacity="0"/>
          </radialGradient>
          <filter id="gateBlur">
            <feGaussianBlur stdDeviation="1.5" result="blur"/>
            <feMerge>
              <feMergeNode in="blur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
          <filter id="softGlow">
            <feGaussianBlur stdDeviation="3" result="blur"/>
            <feMerge>
              <feMergeNode in="blur"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
        </defs>

        <circle cx="200" cy="200" r="190" fill="url(#gateGlow)" class="gate-ambient"/>

        <g id="seal-rings" class="origin-center">
          <circle cx="200" cy="200" r="165" stroke="#c9a227" stroke-width="0.4" stroke-dasharray="3 12" opacity="0.2" class="seal-ring seal-ring-outer"/>
          <circle cx="200" cy="200" r="145" stroke="#c9a227" stroke-width="0.6" stroke-dasharray="1 8" opacity="0.25" class="seal-ring seal-ring-mid"/>
          <circle cx="200" cy="200" r="125" stroke="#d4af37" stroke-width="0.8" opacity="0" stroke-dasharray="2 5" class="seal-ring seal-ring-inner"/>
          <circle cx="200" cy="200" r="105" stroke="#c9a227" stroke-width="1.2" opacity="0" class="seal-ring seal-ring-core"/>
        </g>

        <g id="seal-symbols" class="origin-center" opacity="0">
          <path d="M200 55 L200 95" stroke="#c9a227" stroke-width="0.8" opacity="0.5" class="symbol-line"/>
          <path d="M200 305 L200 345" stroke="#c9a227" stroke-width="0.8" opacity="0.5" class="symbol-line"/>
          <path d="M55 200 L95 200" stroke="#c9a227" stroke-width="0.8" opacity="0.5" class="symbol-line"/>
          <path d="M305 200 L345 200" stroke="#c9a227" stroke-width="0.8" opacity="0.5" class="symbol-line"/>

          <path d="M200 45 L200 85" stroke="#d4af37" stroke-width="0.5" opacity="0.3" class="symbol-line"/>
          <path d="M200 315 L200 355" stroke="#d4af37" stroke-width="0.5" opacity="0.3" class="symbol-line"/>
          <path d="M45 200 L85 200" stroke="#d4af37" stroke-width="0.5" opacity="0.3" class="symbol-line"/>
          <path d="M315 200 L355 200" stroke="#d4af37" stroke-width="0.5" opacity="0.3" class="symbol-line"/>

          <circle cx="200" cy="200" r="70" stroke="#c9a227" stroke-width="0.5" stroke-dasharray="6 8" opacity="0.2" class="inner-rotate"/>
          <circle cx="200" cy="200" r="50" stroke="#d4af37" stroke-width="0.4" opacity="0.15" class="inner-rotate-reverse"/>
          <circle cx="200" cy="200" r="30" stroke="#c9a227" stroke-width="0.3" opacity="0.1" class="inner-rotate"/>
        </g>

        <g id="seal-activate-lines" class="opacity-0">
          <line x1="200" y1="30" x2="200" y2="60" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round" class="activate-line"/>
          <line x1="200" y1="340" x2="200" y2="370" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round" class="activate-line"/>
          <line x1="30" y1="200" x2="60" y2="200" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round" class="activate-line"/>
          <line x1="340" y1="200" x2="370" y2="200" stroke="#d4af37" stroke-width="1.5" stroke-linecap="round" class="activate-line"/>

          <line x1="78" y1="78" x2="98" y2="98" stroke="#c9a227" stroke-width="1" stroke-linecap="round" class="activate-line diagonal-line"/>
          <line x1="302" y1="78" x2="322" y2="98" stroke="#c9a227" stroke-width="1" stroke-linecap="round" class="activate-line diagonal-line"/>
          <line x1="78" y1="322" x2="98" y2="302" stroke="#c9a227" stroke-width="1" stroke-linecap="round" class="activate-line diagonal-line"/>
          <line x1="302" y1="322" x2="322" y2="302" stroke="#c9a227" stroke-width="1" stroke-linecap="round" class="activate-line diagonal-line"/>
        </g>

        <g id="gate-core-group" class="cursor-pointer">
          <circle cx="200" cy="200" r="24" fill="url(#coreGlow)" opacity="0.3" class="core-halo"/>
          <circle id="gate-core" cx="200" cy="200" r="18" fill="#08080c" stroke="#c9a227" stroke-width="1.5" class="core-circle"/>
          <g id="gate-core-inner" class="origin-center opacity-0">
            <circle cx="200" cy="200" r="10" fill="#d4af37" opacity="0.08"/>
            <circle cx="200" cy="200" r="6" fill="#d4af37" opacity="0.12"/>
            <circle cx="200" cy="200" r="3" fill="#d4af37" opacity="0.25"/>
          </g>
        </g>
      </svg>

      <div id="gate-pulse" class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-0">
        <div class="w-[360px] h-[360px] sm:w-[420px] sm:h-[420px] md:w-[520px] md:h-[520px] rounded-full border border-[#c9a227]/15 animate-ping"></div>
      </div>
    </div>
  </div>

  <div id="portal-text" class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none px-6">
    <div class="text-center space-y-5 max-w-[400px] mx-auto opacity-0" id="portal-title-group">
      <div class="space-y-2">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-display text-[#e8d48b] tracking-[0.25em] portal-title" style="text-shadow: 0 0 80px rgba(212, 175, 55, 0.35);">
          灵墟
        </h1>
        <p class="text-[11px] sm:text-xs text-[#c9a227]/60 tracking-[0.4em] uppercase portal-subtitle">
          失落修行文明档案
        </p>
      </div>

      <div class="h-px w-20 mx-auto bg-gradient-to-r from-transparent via-[#c9a227]/30 to-transparent"></div>

      <p class="text-[13px] sm:text-sm text-[#888888] leading-relaxed tracking-wide portal-quote" style="font-style: normal;">
        法门虽隐，真机未亡
      </p>

      <p class="text-[11px] sm:text-xs text-[#666666]/60 tracking-wider portal-hint">
        叩启封印，方入其门
      </p>
    </div>
  </div>

  <div id="portal-cta" class="absolute bottom-20 sm:bottom-28 left-1/2 -translate-x-1/2 flex flex-col items-center gap-5 opacity-0">
    <button
      id="enter-btn"
      class="group relative flex items-center gap-3 px-8 py-3.5 sm:px-10 sm:py-4 rounded-lg overflow-hidden transition-all duration-500 active:scale-[0.98]"
    >
      <div class="absolute inset-0 bg-gradient-to-r from-[#c9a227]/10 via-[#d4af37]/5 to-[#c9a227]/10 border border-[#c9a227]/30 rounded-lg"></div>
      <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-r from-[#c9a227]/8 to-transparent"></div>
      <div class="absolute -inset-[1px] rounded-lg bg-gradient-to-r from-[#c9a227]/20 via-transparent to-[#c9a227]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-[2px]"></div>

      <svg class="relative w-4 h-4 text-[#d4af37]/70 group-hover:text-[#d4af37] transition-colors duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="10"/>
        <path d="M12 6v6l4 2"/>
      </svg>

      <span class="relative text-[#c9a227] tracking-[0.2em] text-[13px] sm:text-sm group-hover:text-[#d4af37] transition-colors duration-500">
        叩启封印
      </span>
    </button>

    <button
      id="skip-btn"
      class="group flex items-center gap-2 text-[11px] sm:text-xs text-[#555555] hover:text-[#888888] tracking-wider transition-colors duration-300"
    >
      <span>直接进入</span>
      <svg class="w-3 h-3 opacity-50 group-hover:opacity-80 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </button>
  </div>

  <div id="portal-transit" class="absolute inset-0 opacity-0 pointer-events-none">
    <div id="transit-tunnel" class="absolute inset-0 flex items-center justify-center">
      <div class="transit-vortex"></div>
    </div>
    <div id="transit-particles" class="absolute inset-0"></div>
  </div>

  <div id="portal-arrival" class="absolute inset-0 flex flex-col items-center justify-center opacity-0 pointer-events-none">
    <div class="text-center space-y-8">
      <div class="archive-icon mx-auto">
        <svg class="w-16 h-16 sm:w-20 sm:h-20 text-[#d4af37]/60" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.8">
          <rect x="20" y="15" width="60" height="70" rx="2"/>
          <path d="M20 30 L80 30"/>
          <path d="M35 15 L35 85"/>
          <circle cx="27" cy="22" r="2" fill="currentColor"/>
          <circle cx="33" cy="22" r="2" fill="currentColor"/>
          <path d="M45 45 L70 45 M45 54 L65 54 M45 63 L60 63 M45 72 L55 72"/>
        </svg>
      </div>

      <div class="space-y-2.5">
        <p class="text-[11px] sm:text-xs text-[#888888]/50 tracking-[0.3em] uppercase">
          已进入档案主卷
        </p>
        <div class="h-px w-24 mx-auto bg-gradient-to-r from-transparent via-[#c9a227]/20 to-transparent"></div>
      </div>

      <div class="space-y-1.5 text-[11px] sm:text-xs tracking-[0.15em] text-[#666666]">
        <p>当前纪元：<span class="text-[#c9a227]/60">末法纪</span></p>
        <p>灵机状态：<span class="text-[#c9a227]/60">衰微</span></p>
        <p>主卷权限：<span class="text-[#d4af37]/70">已解锁</span></p>
      </div>
    </div>
  </div>
</div>

<div id="homepage-wrapper" class="hidden">
  <slot />
</div>

<style>
  #portal-overlay {
    background: linear-gradient(180deg, #030305 0%, #060608 40%, #050507 100%);
  }

  .portal-mist {
    position: absolute;
    width: 180%;
    height: 180%;
    background: radial-gradient(ellipse at center, rgba(201, 162, 39, 0.03) 0%, transparent 55%);
    animation: portalDrift 45s ease-in-out infinite;
    pointer-events: none;
  }

  .portal-mist-1 { top: -40%; left: -40%; animation-delay: 0s; }
  .portal-mist-2 { top: -25%; left: -25%; animation-delay: -18s; animation-duration: 40s; }
  .portal-mist-3 { top: -35%; left: -35%; animation-delay: -28s; animation-duration: 50s; }

  @keyframes portalDrift {
    0%, 100% { transform: translate(0, 0) rotate(0deg); opacity: 0.5; }
    33% { transform: translate(3%, 2%) rotate(0.5deg); opacity: 0.7; }
    66% { transform: translate(-2%, 3%) rotate(-0.5deg); opacity: 0.4; }
  }

  .gate-ambient {
    animation: ambientPulse 5s ease-in-out infinite;
  }

  @keyframes ambientPulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }

  .seal-ring {
    animation: ringRotate 80s linear infinite;
    transform-origin: center;
  }

  .seal-ring-outer { animation-duration: 100s; }
  .seal-ring-mid { animation-duration: 70s; animation-direction: reverse; }
  .seal-ring-inner { animation-duration: 50s; }
  .seal-ring-core { animation-duration: 40s; animation-direction: reverse; }

  @keyframes ringRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .inner-rotate {
    animation: innerRotate 25s linear infinite;
    transform-origin: center;
  }

  .inner-rotate-reverse {
    animation: innerRotateReverse 18s linear infinite;
    transform-origin: center;
  }

  @keyframes innerRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes innerRotateReverse {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }

  #gate-core-group {
    cursor: pointer;
    transition: all 0.4s ease;
  }

  .core-circle {
    transition: all 0.4s ease;
  }

  #gate-core-group:hover .core-circle {
    stroke-width: 2;
    stroke: #d4af37;
    filter: url(#softGlow);
  }

  #gate-core-group:hover .core-halo {
    opacity: 0.5;
  }

  .core-halo {
    transition: opacity 0.4s ease;
  }

  .transit-vortex {
    position: absolute;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse at center,
        rgba(201, 162, 39, 0.08) 0%,
        rgba(201, 162, 39, 0.03) 30%,
        transparent 60%
      );
    animation: vortexPulse 2.5s ease-in-out infinite;
  }

  @keyframes vortexPulse {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.03); opacity: 0.7; }
  }

  .seal-ring.speed-up {
    animation-duration: 8s !important;
  }

  .seal-symbols.speed-up {
    animation-duration: 5s !important;
  }

  #seal-activate-lines.activate .activate-line {
    animation: lineAppear 0.6s ease-out forwards;
  }

  #seal-activate-lines.activate .diagonal-line {
    animation: lineAppear 0.5s ease-out 0.2s forwards;
  }

  @keyframes lineAppear {
    from { opacity: 0; stroke-width: 0.5; }
    to { opacity: 0.8; stroke-width: 1.5; }
  }

  #seal-activate-lines.bright .activate-line {
    stroke: #d4af37;
    stroke-width: 2;
    opacity: 1;
  }

  #gate-core-inner.pulse-glow .inner-rotate,
  #gate-core-inner.pulse-glow .inner-rotate-reverse {
    animation: innerRotate 8s linear infinite, pulseGlow 2s ease-in-out infinite;
  }

  @keyframes pulseGlow {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.35; }
  }

  .symbol-line {
    animation: symbolPulse 3s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * 0.5s);
  }

  @keyframes symbolPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.6; }
  }

  @media (max-width: 640px) {
    .portal-title {
      letter-spacing: 0.2em;
    }

    .seal-ring {
      animation-duration: 40s !important;
    }

    .seal-ring-outer { animation-duration: 50s; }
    .seal-ring-mid { animation-duration: 35s; }
    .seal-ring-inner { animation-duration: 25s; }
    .seal-ring-core { animation-duration: 20s; }

    .inner-rotate { animation-duration: 12s; }
    .inner-rotate-reverse { animation-duration: 10s; }
  }

  @media (prefers-reduced-motion: reduce) {
    .portal-mist,
    .seal-ring,
    .inner-rotate,
    .inner-rotate-reverse,
    .gate-ambient,
    .transit-vortex,
    .symbol-line,
    #gate-core-inner.pulse-glow .inner-rotate,
    #gate-core-inner.pulse-glow .inner-rotate-reverse {
      animation: none;
    }

    .seal-ring.speed-up,
    .seal-symbols.speed-up {
      animation-duration: 0s !important;
    }
  }
</style>
