---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveCard from '@components/widgets/ArchiveCard.astro';
import ScrollReveal from '@components/interactive/ScrollReveal.astro';
import Timeline from '@components/ui/Timeline.astro';

const featuredArticles = [
  {
    title: '末法纪总论',
    description: '阐释末法纪的形成原因、三重含义及其对修行文明的深远影响',
    href: '/archive/end-of-dharma-age',
    category: '核心卷宗',
    color: 'gold' as const,
  },
  {
    title: '六纪时代划分',
    description: '从太初纪到末法纪，系统梳理修行文明的六大时代分期',
    href: '/archive/six-eras',
    category: '时代分期',
    color: 'gold' as const,
  },
  {
    title: '灵气衰退与法脉隐遁',
    description: '探讨灵炁衰竭的规律与修行传承断裂的历史进程',
    href: '/archive/decline-of-qi',
    category: '文明演变',
    color: 'gold' as const,
  },
  {
    title: '文学中的修行文明残影',
    description: '从仙侠小说看失落文明的文学重构与再造',
    href: '/archive/cultivation-in-literature',
    category: '残痕研究',
    color: 'gold' as const,
  },
];

const eraPhenomena = [
  { title: '灵机稀薄', description: '天地灵气日趋淡薄，修行者感应天地愈发困难' },
  { title: '法脉断续', description: '修行传承多有断裂，完整法脉愈发罕见' },
  { title: '神异难显', description: '神通异能难以显现，奇迹成为不可证明之事' },
  { title: '宗门隐遁', description: '修行宗门转入隐秘，世间难得一见' },
  { title: '真传散佚', description: '核心口诀与心法在传承中逐渐遗失' },
  { title: '文学化再造', description: '真实修行记载化为志怪小说与仙侠故事' },
];

const remnantCategories = [
  {
    title: '典籍残痕',
    description: '《黄帝内经》《山海经》《抱朴子》等典籍中保存的修行记载',
    href: '/medicine/huangdi-neijing',
    icon: '📜',
    color: 'jade' as const,
  },
  {
    title: '宗教残痕',
    description: '佛教、道教中保留的修行方法与境界理论',
    href: '/dharma/buddhism-and-daoism',
    icon: '🏛️',
    color: 'sapphire' as const,
  },
  {
    title: '民俗残痕',
    description: '民间传说、节庆习俗中残留的修行文明印记',
    href: '/myth/shanhai-overview',
    icon: '🗺️',
    color: 'amethyst' as const,
  },
  {
    title: '境界体系',
    description: '仙侠小说中系统化的修行境界设定',
    href: '/realms/cultivation-realm-system',
    icon: '⚔️',
    color: 'ochre' as const,
  },
];
---

<BaseLayout title="末法档案 - 灵墟" description="末法时代的文明碎片，典籍与传说的交汇之处">
  <article class="pt-20 pb-16">
    <header class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-[#c9a227]/[0.03] via-transparent to-transparent"></div>
      <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full bg-gradient-to-br from-[#c9a227]/[0.06] to-transparent blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-64 h-64 rounded-full bg-gradient-to-tr from-[#6b4a8a]/[0.04] to-transparent blur-2xl"></div>

      <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
        <nav class="flex items-center gap-2 text-sm mb-8" aria-label="面包屑导航">
          <a href="/" class="text-[#666666] hover:text-[#c9a227] transition-colors">首页</a>
          <span class="text-[#444444]">/</span>
          <span class="text-[#888888]">末法档案</span>
        </nav>

        <div class="flex items-center gap-3 mb-6">
          <span class="px-3 py-1 text-xs font-medium tracking-[0.15em] uppercase border border-[#c9a227]/40 text-[#c9a227] rounded-full">
            档案馆
          </span>
          <span class="px-3 py-1 text-xs text-[#888888] border border-[#333333]/50 rounded-full">
            核心卷宗
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-display text-[#e8d48b] mb-6 tracking-wide leading-tight">
          末法档案
        </h1>

        <p class="text-xl sm:text-2xl text-[#c9a227]/80 font-light mb-6 leading-relaxed">
          灵机衰退之后的卷宗与遗痕
        </p>

        <blockquote class="border-l-2 border-[#8b6914] pl-6 py-3 my-6 max-w-3xl">
          <p class="text-lg text-[#888888] italic leading-relaxed">
            古法未必尽绝，只是世人已不复识之。
          </p>
        </blockquote>

        <p class="text-[#888888] leading-relaxed mb-8 max-w-3xl">
          此卷记述末法纪的形成、六纪的演变、法脉的隐遁与现世残痕的留存方式。凡灵墟诸卷，皆可由此追索其源。
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="/archive/end-of-dharma-age"
            class="group inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[#c9a227]/[0.08] border border-[#c9a227]/30 text-[#d4af37] hover:bg-[#c9a227]/[0.12] hover:border-[#c9a227]/50 transition-all"
          >
            <span>查阅主卷</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </a>
          <a
            href="#timeline"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-[#333333] text-[#888888] hover:text-[#c9a227] hover:border-[#c9a227]/30 transition-all"
          >
            <span>浏览时代轴</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>

        <div class="gold-line mt-12 max-w-[240px] opacity-50"></div>
      </div>
    </header>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#d4af37] mb-8 tracking-wide">何为末法纪</h2>
          <div class="prose-lingxu max-w-3xl">
            <p>
              "末法"二字，最早见于佛教经典。佛陀预言：正法住世五百年，像法住世一千年，末法住世一万年。此后，修行者将逐渐失去悟道的机会，世间将陷入黑暗与混乱。
            </p>
            <p>
              在灵墟的世界观中，末法纪不仅是一个宗教概念，更是修行文明走向沉寂的历史进程。灵气衰竭、法脉断裂、神异不显——这些现象共同构成了末法纪的特征。
            </p>
            <p>
              灵墟将现代时代定义为末法纪的深化期：灵炁淡薄到几乎不可感知，完整的修行传承几乎断绝，唯有在典籍、宗教、民俗与文学的残痕中，才能窥见昔日修行文明的辉煌。
            </p>
          </div>
        </section>
      </ScrollReveal>

      <section id="timeline" class="py-16 border-b border-[#2a2a2a]/50">
        <ScrollReveal>
          <h2 class="text-2xl sm:text-3xl font-display text-[#d4af37] mb-8 tracking-wide">六纪时代总览</h2>
        </ScrollReveal>
        <Timeline />
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#d4af37] mb-8 tracking-wide">末法现象</h2>
          <p class="text-[#888888] mb-8 max-w-3xl">
            末法纪的特征并非单一现象，而是多种文明衰退迹象的集合。这些现象彼此关联，共同指向修行文明的历史性转折。
          </p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {eraPhenomena.map((phenomenon) => (
              <div class="p-5 rounded-lg bg-[#0d0d0d]/50 border border-[#2a2a2a]/50 hover:border-[#c9a227]/30 transition-all group">
                <h3 class="text-lg font-display text-[#d4af37] mb-2 group-hover:text-[#e8d48b] transition-colors">
                  {phenomenon.title}
                </h3>
                <p class="text-sm text-[#888888] leading-relaxed">
                  {phenomenon.description}
                </p>
              </div>
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#d4af37] mb-8 tracking-wide">现世残痕</h2>
          <p class="text-[#888888] mb-8 max-w-3xl">
            末法纪并非全然断灭。修行文明的余绪以各种形式残留于现实之中，等待被重新诠释与理解。
          </p>
          <div class="grid sm:grid-cols-2 gap-4">
            {remnantCategories.map((category) => (
              <a
                href={category.href}
                class="group p-5 rounded-lg bg-[#0d0d0d]/50 border border-[#2a2a2a]/50 hover:border-[#c9a227]/30 transition-all flex items-start gap-4"
              >
                <span class="text-2xl">{category.icon}</span>
                <div>
                  <h3 class={`text-lg font-display mb-1 group-hover:text-[#e8d48b] transition-colors ${
                    category.color === 'jade' ? 'text-[#5ababa]' :
                    category.color === 'sapphire' ? 'text-[#6b9ad4]' :
                    category.color === 'amethyst' ? 'text-[#a878b8]' :
                    category.color === 'ochre' ? 'text-[#ba7a5a]' :
                    'text-[#d4af37]'
                  }`}>
                    {category.title}
                  </h3>
                  <p class="text-sm text-[#888888] leading-relaxed">
                    {category.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16 border-b border-[#2a2a2a]/50">
          <h2 class="text-2xl sm:text-3xl font-display text-[#d4af37] mb-8 tracking-wide">精选卷宗</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {featuredArticles.map((article) => (
              <ArchiveCard
                title={article.title}
                description={article.description}
                href={article.href}
                category={article.category}
                color={article.color}
              />
            ))}
          </div>
        </section>
      </ScrollReveal>

      <ScrollReveal>
        <section class="py-16">
          <h2 class="text-2xl sm:text-3xl font-display text-[#d4af37] mb-8 tracking-wide">关联路径</h2>
          <p class="text-[#888888] mb-8 max-w-3xl">
            从末法档案出发，可沿以下路径深入探索修行文明的各个面向。
          </p>
          <div class="space-y-4">
            <a
              href="/medicine"
              class="group block p-5 rounded-lg bg-[#2d8a8a]/[0.04] border border-[#2d8a8a]/20 hover:border-[#5ababa]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#5ababa] mb-1">身体修持与现实残痕</h3>
              <p class="text-sm text-[#888888]">从《黄帝内经》探索身体与能量的奥秘 → 性命医道</p>
            </a>
            <a
              href="/dharma"
              class="group block p-5 rounded-lg bg-[#2d4a6b]/[0.04] border border-[#2d4a6b]/20 hover:border-[#6b9ad4]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#6b9ad4] mb-1">佛道思想与法衰逻辑</h3>
              <p class="text-sm text-[#888888]">梳理佛教东渐与道教兴起的修行传承 → 佛道法脉</p>
            </a>
            <a
              href="/realms"
              class="group block p-5 rounded-lg bg-[#8a4a2d]/[0.04] border border-[#8a4a2d]/20 hover:border-[#ba7a5a]/40 transition-all"
            >
              <h3 class="text-lg font-display text-[#ba7a5a] mb-1">文学重构与境界体系</h3>
              <p class="text-sm text-[#888888]">从仙侠小说看失落文明的文学再造 → 仙途境界</p>
            </a>
          </div>
        </section>
      </ScrollReveal>

      <footer class="py-12 text-center">
        <div class="gold-line max-w-[200px] mx-auto mb-8 opacity-30"></div>
        <p class="text-[#666666] text-sm">
          末法档案 · 灵墟 · 末法时代修行文明档案馆
        </p>
        <p class="text-[#555555] text-xs mt-2">
          愿见者得度，闻者觉悟
        </p>
      </footer>
    </div>
  </article>
</BaseLayout>
